{
	"files.watcherExclude": {
		"**/routeTree.gen.ts": true
	},
	"search.exclude": {
		"**/routeTree.gen.ts": true
	},
	"files.readonlyInclude": {
		"**/routeTree.gen.ts": true
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "explicit"
	},
	"workbench.colorCustomizations": {
		"activityBar.background": "#033333",
		"titleBar.activeBackground": "#054848",
		"titleBar.activeForeground": "#E9FEFE",
		"titleBar.inactiveBackground": "#033333",
		"titleBar.inactiveForeground": "#E9FEFE",
		"statusBar.background": "#033333",
		"statusBar.foreground": "#E9FEFE",
		"statusBar.debuggingBackground": "#033333",
		"statusBar.debuggingForeground": "#E9FEFE",
		"statusBar.noFolderBackground": "#033333",
		"statusBar.noFolderForeground": "#E9FEFE"
	},
	"windowColors.baseColor": "#0a9e9e"
}
